{
  "name": "03 - Telegram Handler",
  "nodes": [
    {
      "parameters": {
        "updates": ["message", "callback_query"],
        "additionalFields": {}
      },
      "id": "tg-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [240, 300],
      "credentials": {
        "telegramApi": {
          "id": "tg-cred-1",
          "name": "AlgoTrader Telegram"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const update = $input.first().json;\n\n// Verify chat_id matches authorized chat\nconst authorizedChatId = $env.TELEGRAM_CHAT_ID;\nconst chatId = String(\n  update.message?.chat?.id ||\n  update.callback_query?.message?.chat?.id ||\n  ''\n);\n\nif (chatId !== String(authorizedChatId)) {\n  return [{ json: { authorized: false, cmd: 'unauthorized', chatId } }];\n}\n\nlet cmd = 'unknown';\nlet signalId = null;\nlet callbackQueryId = null;\n\nif (update.callback_query) {\n  const data = update.callback_query.data || '';\n  callbackQueryId = update.callback_query.id;\n  if (data.startsWith('approve_')) {\n    cmd = 'approve';\n    signalId = data.replace('approve_', '');\n  } else if (data.startsWith('reject_')) {\n    cmd = 'reject';\n    signalId = data.replace('reject_', '');\n  }\n} else if (update.message?.text) {\n  const text = update.message.text.trim();\n  if (text === '/status')          cmd = 'status';\n  else if (text === '/trades')     cmd = 'trades';\n  else if (text === '/stop')       cmd = 'stop';\n  else if (text === '/start')      cmd = 'start';\n  else if (text.startsWith('/approve_')) {\n    cmd = 'approve';\n    signalId = text.replace('/approve_', '');\n  } else if (text.startsWith('/reject_')) {\n    cmd = 'reject';\n    signalId = text.replace('/reject_', '');\n  }\n}\n\nreturn [{ json: { authorized: true, cmd, signalId, chatId, callbackQueryId } }];\n"
      },
      "id": "parse-message",
      "name": "Parse & Authorize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
          "conditions": [
            {
              "id": "auth-check",
              "leftValue": "={{ $json.authorized }}",
              "rightValue": true,
              "operator": {"type": "boolean", "operation": "true"}
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-authorized",
      "name": "Authorized?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-approve", "leftValue": "={{ $json.cmd }}", "rightValue": "approve", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "approve"},
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-reject", "leftValue": "={{ $json.cmd }}", "rightValue": "reject", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "reject"},
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-status", "leftValue": "={{ $json.cmd }}", "rightValue": "status", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "status"},
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-trades", "leftValue": "={{ $json.cmd }}", "rightValue": "trades", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "trades"},
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-stop", "leftValue": "={{ $json.cmd }}", "rightValue": "stop", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "stop"},
            {"conditions": {"options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"}, "conditions": [{"id": "sw-start", "leftValue": "={{ $json.cmd }}", "rightValue": "start", "operator": {"type": "string", "operation": "equals"}}], "combinator": "and"}, "renameOutput": true, "outputKey": "start"}
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "switch-cmd",
      "name": "Switch Command",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [900, 300]
    },
    {
