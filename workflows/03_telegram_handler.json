          "id": "tg-cred-1",
          "name": "AlgoTrader Telegram"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT coin, direction, entry_price, exit_price, pnl_usdt, pnl_pct, exit_reason, exit_time FROM trades WHERE status = 'closed' ORDER BY exit_time DESC LIMIT 10",
        "options": {}
      },
      "id": "db-trades",
      "name": "DB: Last 10 Trades",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1120, 420],
      "credentials": {
        "postgres": {
          "id": "pg-cred-1",
          "name": "AlgoTrader PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const trades = $input.all().map(i => i.json);\n\nif (trades.length === 0) {\n  return [{ json: { text: '📋 *Žádné uzavřené obchody*' } }];\n}\n\nconst lines = trades.map(t => {\n  const icon = parseFloat(t.pnl_usdt) >= 0 ? '🟢' : '🔴';\n  const pnlSign = parseFloat(t.pnl_usdt) >= 0 ? '+' : '';\n  const date = t.exit_time ? new Date(t.exit_time).toLocaleDateString('cs-CZ') : 'N/A';\n  return `${icon} ${t.coin} ${t.direction.toUpperCase()} | ${pnlSign}$${parseFloat(t.pnl_usdt).toFixed(2)} (${pnlSign}${parseFloat(t.pnl_pct).toFixed(2)}%) | ${date}`;\n});\n\nconst text = [`📋 *Posledních ${trades.length} obchodů*`, ``].concat(lines).join('\\n');\nreturn [{ json: { text } }];\n"
      },
      "id": "format-trades",
      "name": "Format Trades",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 420]
    },
