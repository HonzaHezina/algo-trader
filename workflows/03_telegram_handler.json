    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.total_value, p.available_capital, p.total_pnl_usdt, p.total_pnl_pct, p.today_pnl_usdt, p.total_trades, p.winning_trades, p.losing_trades, p.consecutive_losses, p.system_active, t.id, t.coin, t.direction, t.entry_price, t.current_stop, t.entry_time FROM portfolio p LEFT JOIN trades t ON t.status = 'open' WHERE p.id = 1",
        "options": {}
      },
      "id": "db-status",
      "name": "DB: Get Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1120, 300],
      "credentials": {
        "postgres": {
          "id": "pg-cred-1",
          "name": "AlgoTrader PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst p = rows[0];\nconst openTrades = rows.filter(r => r.id !== null);\n\nconst sysIcon = p.system_active ? '⚡ AKTIVNÍ' : '⛔ ZASTAVEN';\nconst pnlSign = parseFloat(p.total_pnl_usdt) >= 0 ? '+' : '';\nconst todaySign = parseFloat(p.today_pnl_usdt) >= 0 ? '+' : '';\nconst pnlIcon = parseFloat(p.total_pnl_usdt) >= 0 ? '📈' : '📉';\nconst winRate = p.total_trades > 0 ? (p.winning_trades / p.total_trades * 100).toFixed(1) : 0;\n\nlet tradesSection = '';\nif (openTrades.length > 0) {\n  const lines = openTrades.map(t => {\n    const icon = t.direction === 'long' ? '🟢' : '🔴';\n    return `  ${icon} ${t.coin} ${t.direction.toUpperCase()} @ ${t.entry_price}\\n     Stop: ${t.current_stop}`;\n  });\n  tradesSection = `\\n📂 *Otevřené pozice: ${openTrades.length}/3*\\n${lines.join('\\n')}\\n`;\n} else {\n  tradesSection = '\\n📂 *Otevřené pozice: 0/3*\\n';\n}\n\nconst text = [\n  `📊 *Portfolio Status*`,\n  ``,\n  `💰 Kapitál: $${parseFloat(p.total_value).toFixed(2)}`,\n  `${pnlIcon} Celkový P&L: ${pnlSign}$${parseFloat(p.total_pnl_usdt).toFixed(2)} (${pnlSign}${parseFloat(p.total_pnl_pct).toFixed(2)}%)`,\n  `📅 Dnes: ${todaySign}$${parseFloat(p.today_pnl_usdt).toFixed(2)}`,\n  tradesSection,\n  `📊 Win Rate: ${winRate}% (${p.winning_trades}W / ${p.losing_trades}L)`,\n  `🔴 Consecutive losses: ${p.consecutive_losses}`,\n  `⚡ Systém: ${sysIcon}`\n].join('\\n');\n\nreturn [{ json: { text } }];\n"
      },
      "id": "format-status",
      "name": "Format Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ $json.text }}",
        "additionalFields": {"parse_mode": "Markdown"}
      },
      "id": "reply-status",
      "name": "Reply: Status",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1560, 300],
      "credentials": {
