# AlgoTrader — Environment Variables
# Zkopíruj do .env a vyplň hodnoty

# ============================================
# PostgreSQL
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=algotrader
POSTGRES_USER=algotrader
POSTGRES_PASSWORD=CHANGE_ME

# ============================================
# Binance API
# ============================================
# Vytvoř na https://www.binance.com/en/my/settings/api-management
# Povol: Enable Reading, Enable Spot Trading
# IP whitelist: nastav na IP tvého VPS
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ============================================
# Telegram Bot
# ============================================
# Vytvoř přes @BotFather na Telegramu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # tvůj osobní chat ID
TELEGRAM_ERROR_CHAT_ID=    # separátní chat pro errory (volitelné)

# ============================================
# n8n
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME
N8N_WEBHOOK_URL=https://n8n.your-domain.com
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY_!

# ============================================
# OpenClaw
# ============================================
# Docker image: ghcr.io/openclaw/openclaw:latest
# Port: 18789 (web UI + REST API)
# Docs: https://docs.openclaw.ai
OPENCLAW_API_URL=http://localhost:18789
OPENCLAW_API_KEY=          # OPENCLAW_TOKEN ze spuštěného instance
ANTHROPIC_API_KEY=         # API klíč pro Claude modely

# ============================================
# MindsDB (volitelné — začni bez)
# ============================================
MINDSDB_HOST=localhost
MINDSDB_PORT=47334
MINDSDB_USER=mindsdb
MINDSDB_PASSWORD=

# ============================================
# General
# ============================================
ENVIRONMENT=development    # development | production
LOG_LEVEL=info             # debug | info | warning | error
TIMEZONE=UTC
DOMAIN=algotrader.example.com
